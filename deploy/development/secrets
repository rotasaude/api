# Kamal secrets — development
# Lido pelo Kamal como shell script. Valores NUNCA aparecem aqui em texto plano.
# Ver ADR-0011.
#
# Em dev aceitamos fallback para .env.development.local (na raiz de apps/api/),
# ignorado pelo git. Em prod, vem só do cofre (ver production/secrets).

# Carrega .env.development.local se existir (formato KEY=value, uma por linha).
if [ -f "${KAMAL_CONFIG_DIR:-.}/.env.development.local" ]; then
  set -o allexport
  . "${KAMAL_CONFIG_DIR:-.}/.env.development.local"
  set +o allexport
fi

# Registry — token de leitura/escrita do ghcr para o usuário rota-saude-bot.
KAMAL_REGISTRY_PASSWORD=${KAMAL_REGISTRY_PASSWORD:?defina no .env.development.local}

# Rails master key (config/credentials/development.key — NUNCA commitada).
RAILS_MASTER_KEY=${RAILS_MASTER_KEY:?defina no .env.development.local}

# Postgres do accessory (mesma máquina em dev).
POSTGRES_PASSWORD=${POSTGRES_PASSWORD:?defina no .env.development.local}
DATABASE_URL=${DATABASE_URL:-postgres://rota_saude:${POSTGRES_PASSWORD}@127.0.0.1:5432/rota_saude_development}

# WhatsApp Cloud API — tokens de sandbox em dev.
WHATSAPP_VERIFY_TOKEN=${WHATSAPP_VERIFY_TOKEN:?defina no .env.development.local}
WHATSAPP_APP_SECRET=${WHATSAPP_APP_SECRET:?defina no .env.development.local}
WHATSAPP_ACCESS_TOKEN=${WHATSAPP_ACCESS_TOKEN:?defina no .env.development.local}
